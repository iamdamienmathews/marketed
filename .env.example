# Copy this file to .env and fill in what you have. The platform runs
# and is fully testable with NONE of these set except the first two —
# every integration below degrades gracefully until configured.

# --- Required ---
SESSION_SECRET=replace-with-a-long-random-string
CREDENTIALS_SECRET=replace-with-a-different-long-random-string

# --- First admin account (created by `npm run seed`) ---
ADMIN_NAME=Your Name
ADMIN_EMAIL=you@youragency.com
ADMIN_PASSWORD=choose-a-strong-password

# --- Server ---
PORT=3000
NODE_ENV=development
# The public URL this app is served from. Used to build absolute links in
# emails (calendar downloads, join links) and as the default OAuth redirect
# base. Set this to your real domain once deployed, e.g.:
# BASE_URL=https://yourapp.up.railway.app
BASE_URL=http://localhost:3000

# Where SQLite files (vantage.db, sessions.db) are stored. Leave blank to
# use the local ./data folder. On Railway, set this to your mounted
# Volume's path (e.g. /data) so your database survives redeploys.
DATA_DIR=

# --- Business hours for discovery-call slots ---
WORK_START_HOUR=9
WORK_END_HOUR=17
SLOT_MINUTES=30
TZ_OFFSET_HOURS=0

# --- Email (any SMTP provider — Gmail, SendGrid, Postmark, Mailgun, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@youragency.com

# --- Google Calendar + Meet (Google Cloud Console > OAuth Client ID) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/google/callback

# --- Zoom (Zoom App Marketplace > Server-to-Server OAuth app) ---
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_HOST_EMAIL=you@youragency.com

# --- Google Ads (Google Ads Developer Token, applied for separately) ---
GOOGLE_ADS_DEVELOPER_TOKEN=

# --- Channel sync frequency (cron expression) ---
SYNC_CRON=*/5 * * * *
